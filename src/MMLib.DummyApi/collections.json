{
  "collections": [
    {
      "name": "products",
      "displayName": "Products",
      "description": "Product catalog for e-commerce scenarios",
      "authRequired": false,
      "seedCount": 50,
      "schema": {
        "type": "object",
        "required": ["name", "price"],
        "properties": {
          "name": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Product name"
          },
          "description": { 
            "type": "string",
            "maxLength": 500,
            "description": "Product description"
          },
          "price": { 
            "type": "number",
            "minimum": 0.01,
            "maximum": 999999.99,
            "description": "Product price in EUR"
          },
          "stockQuantity": { 
            "type": "integer",
            "minimum": 0,
            "maximum": 10000,
            "description": "Available stock quantity"
          },
          "category": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "description": "Product category"
          },
          "sku": { 
            "type": "string",
            "minLength": 3,
            "maxLength": 50,
            "description": "Stock keeping unit"
          },
          "imageUrl": { 
            "type": "string",
            "format": "uri",
            "description": "Product image URL"
          }
        }
      },
      "backgroundJob": {
        "fieldPath": "calculatedPrice",
        "operation": "sum:price",
        "delayMs": 2000
      },
      "rules": [
        {
          "priority": 1,
          "method": "GET",
          "when": [
            { "source": "query", "field": "category", "operator": "equals", "value": "error" }
          ],
          "response": {
            "statusCode": 500,
            "body": { "error": "Simulated server error for category=error" }
          }
        }
      ]
    },
    {
      "name": "orders",
      "displayName": "Orders",
      "description": "Order management with authentication",
      "authRequired": true,
      "seedCount": 20,
      "schema": {
        "type": "object",
        "required": ["customerId", "totalAmount"],
        "properties": {
          "customerId": { 
            "type": "string",
            "minLength": 1,
            "description": "Customer identifier"
          },
          "customerName": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Customer full name"
          },
          "customerEmail": { 
            "type": "string",
            "format": "email",
            "description": "Customer email address"
          },
          "totalAmount": { 
            "type": "number",
            "minimum": 0,
            "maximum": 1000000,
            "description": "Total order amount"
          },
          "status": { 
            "type": "string",
            "enum": ["pending", "processing", "completed", "cancelled"],
            "description": "Order status"
          },
          "shippingAddress": { 
            "type": "string",
            "minLength": 5,
            "maxLength": 200,
            "description": "Shipping address"
          },
          "shippingCity": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Shipping city"
          },
          "shippingCountry": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Shipping country"
          }
        }
      },
      "backgroundJob": {
        "fieldPath": "status",
        "operation": "sequence:pending,processing,completed",
        "delayMs": 3000
      }
    },
    {
      "name": "customers",
      "displayName": "Customers",
      "description": "Customer database for CRM scenarios",
      "authRequired": false,
      "seedCount": 30,
      "schema": {
        "type": "object",
        "required": ["firstName", "lastName", "email"],
        "properties": {
          "firstName": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "description": "Customer first name"
          },
          "lastName": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "description": "Customer last name"
          },
          "email": { 
            "type": "string",
            "format": "email",
            "description": "Customer email address"
          },
          "phone": { 
            "type": "string",
            "pattern": "^[+]?[(]?[0-9]{1,4}[)]?[-\\s.]?[(]?[0-9]{1,4}[)]?[-\\s.]?[0-9]{1,9}$",
            "description": "Phone number"
          },
          "company": { 
            "type": "string",
            "maxLength": 100,
            "description": "Company name"
          },
          "address": { 
            "type": "string",
            "minLength": 5,
            "maxLength": 200,
            "description": "Street address"
          },
          "city": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "City"
          },
          "country": { 
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Country"
          },
          "zipCode": { 
            "type": "string",
            "minLength": 3,
            "maxLength": 20,
            "description": "Postal/ZIP code"
          }
        }
      },
      "rules": [
        {
          "priority": 1,
          "method": "GET",
          "when": [
            { "source": "query", "field": "status", "operator": "equals", "value": "vip" }
          ],
          "response": {
            "statusCode": 200,
            "body": [
              { "id": "vip-001", "firstName": "John", "lastName": "VIP", "email": "john.vip@example.com", "status": "vip" }
            ],
            "headers": { "X-Custom-Header": "VIP-Response" }
          }
        }
      ]
    }
  ]
}
