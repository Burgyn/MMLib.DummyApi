@host = http://localhost:5229
@ApiKey = test-api-key-123

### ===== COLLECTION DEFINITIONS =====

### Get all collection definitions
GET {{host}}/custom/_definitions
Accept: application/json

### Get specific collection definition
GET {{host}}/custom/_definitions/products
Accept: application/json

### Create new collection
POST {{host}}/custom/_definitions
Content-Type: application/json

{
  "name": "users",
  "displayName": "Users",
  "description": "User accounts",
  "authRequired": false,
  "seedCount": 10,
  "schema": {
    "type": "object",
    "required": ["firstName", "lastName", "email"],
    "properties": {
      "firstName": { "type": "string" },
      "lastName": { "type": "string" },
      "email": { "type": "string" },
      "phone": { "type": "string" }
    }
  }
}

### Delete collection
DELETE {{host}}/custom/_definitions/users

### ===== PRODUCTS (Dynamic Collection) =====

### Get all products
GET {{host}}/products
Accept: application/json

### Get all products with filter
GET {{host}}/products?category=Electronics
Accept: application/json

### Get product by ID
GET {{host}}/products/00000000-0000-0000-0000-000000000001
Accept: application/json

### Create product
POST {{host}}/products
Content-Type: application/json

{
  "name": "Test Product",
  "description": "A test product",
  "price": 99.99,
  "stockQuantity": 50,
  "category": "Electronics"
}

### Create product with background delay
POST {{host}}/products
Content-Type: application/json
X-Background-Delay: 5000

{
  "name": "Product with Delay",
  "price": 199.99,
  "stockQuantity": 25,
  "category": "Electronics"
}

### Test rule: error response
GET {{host}}/products?category=error
Accept: application/json

### ===== ORDERS (Authenticated Collection) =====

### Get all orders (requires auth)
GET {{host}}/orders
Accept: application/json
X-Api-Key: {{ApiKey}}

### Create order (requires auth)
POST {{host}}/orders
Content-Type: application/json
X-Api-Key: {{ApiKey}}

{
  "customerId": "cust-001",
  "customerName": "John Doe",
  "customerEmail": "john@example.com",
  "totalAmount": 199.99,
  "status": "pending"
}

### ===== CUSTOMERS (With Rules) =====

### Get all customers
GET {{host}}/customers
Accept: application/json

### Get VIP customers (triggers rule)
GET {{host}}/customers?status=vip
Accept: application/json

### ===== SIMULATION HEADERS =====

### Simulate delay
GET {{host}}/products
Accept: application/json
X-Simulate-Delay: 2000

### Simulate error
GET {{host}}/products
Accept: application/json
X-Simulate-Error: true

### Simulate retry (call 3 times - first 2 fail)
GET {{host}}/products
Accept: application/json
X-Simulate-Retry: 3
X-Request-Id: retry-test-123

### Chaos failure rate (30% chance of error)
GET {{host}}/products
Accept: application/json
X-Chaos-FailureRate: 0.3

### Chaos latency range
GET {{host}}/products
Accept: application/json
X-Chaos-LatencyRange: 100-500

### ===== SYSTEM =====

### Reset all collections
POST {{host}}/reset

### Reset specific collection
POST {{host}}/reset?collection=products

### Health check
GET {{host}}/health
Accept: application/json

### ===== PERFORMANCE =====

### Generate payload
GET {{host}}/perf/payload?size=1kb
Accept: application/json

### Generate items
GET {{host}}/perf/payload?items=100
Accept: application/json

### Get counter
GET {{host}}/perf/counter
Accept: application/json

### Increment counter
POST {{host}}/perf/counter/increment

### Reset counter
POST {{host}}/perf/counter/reset
