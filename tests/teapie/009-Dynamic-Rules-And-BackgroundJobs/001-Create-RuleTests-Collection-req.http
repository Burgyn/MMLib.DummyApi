### Create a dynamic collection with rules and background job configuration
# @name CreateRuleTestsCollectionRequest
## TEST-EXPECT-STATUS: [201, 409]
## TEST-HAS-BODY
POST {{ApiBaseUrl}}/custom/_definitions
Content-Type: application/json

{
    "name": "ruletests",
    "displayName": "Rule Tests",
    "description": "Collection for testing response rules on dynamic collections",
    "authRequired": false,
    "seedCount": 0,
    "rules": [
        {
            "priority": 1,
            "method": "GET",
            "when": [
                { "source": "query", "field": "status", "operator": "equals", "value": "error" }
            ],
            "response": {
                "statusCode": 500,
                "body": { "error": "rule-triggered" }
            }
        },
        {
            "priority": 2,
            "method": "GET",
            "when": [
                { "source": "header", "field": "X-Test-Mode", "operator": "exists" }
            ],
            "response": {
                "statusCode": 200,
                "body": { "mode": "test" },
                "headers": { "X-Rule-Applied": "true" }
            }
        },
        {
            "priority": 3,
            "method": "POST",
            "when": [
                { "source": "body", "field": "type", "operator": "equals", "value": "blocked" }
            ],
            "response": {
                "statusCode": 403,
                "body": { "error": "blocked-type" }
            }
        },
        {
            "priority": 4,
            "method": "*",
            "when": [
                { "source": "query", "field": "price", "operator": "greaterThan", "value": "1000" }
            ],
            "response": {
                "statusCode": 400,
                "body": { "error": "price-too-high" }
            }
        },
        {
            "priority": 5,
            "method": "GET",
            "when": [
                { "source": "query", "field": "name", "operator": "contains", "value": "test" }
            ],
            "response": {
                "statusCode": 200,
                "body": { "filtered": true }
            }
        },
        {
            "priority": 6,
            "method": "GET",
            "when": [
                { "source": "query", "field": "code", "operator": "startsWith", "value": "PRE" }
            ],
            "response": {
                "statusCode": 200,
                "body": { "prefix": true }
            }
        },
        {
            "priority": 7,
            "method": "GET",
            "when": [
                { "source": "query", "field": "value", "operator": "range", "value": "10,50" }
            ],
            "response": {
                "statusCode": 200,
                "body": { "inRange": true }
            }
        }
    ],
    "backgroundJob": {
        "fieldPath": "status",
        "operation": "sequence:new,processing,done",
        "delayMs": 5000
    }
}
